*** clic sur un bouton

// component
myClickFunction(event) {
    alert("Button is clicked");
    console.log(event);
}

// html
<button (click) = "myClickFunction($event)">
   Click Me
</button>


*** sélection élément

// component
changemonths(event) {
    console.log("Changed month from the Dropdown");
    console.log(event);
}

// html
<select (change) = "changemonths($event)">
    <option *ngFor = "let i of months">{{i}}</option>
</select>