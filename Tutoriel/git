---Démarrer un projet : 

git init

+ créer un fichier .gitignore


---Récupérer un projet :

git clone URL


---Commit et push

git add . = référencer fichier nouvellement créé
git commit -m "message"
git push origin nomBranche


---Récupérer une mise à jour

git pull


---Supprimer un commit

git reset --hard HEAD~1 = supprimer commit que en local

git revert HEAD = supprimer commit sur dépot distant


---Gérer les branches

git branch nomBranche = créer une branche

git checkout nomBranche = se placer dans nomBranche

git checkout -b nomBranch = créer une branche et s'y placer

git rebase branche1 branche2


---Sauvegarder son travail sans commit

git stach = sauvegarder

git stash pop = récupérer son travail et supprimer la sauvegarde

git stash apply = récupérer son travail sans supprimer la sauvegarde







